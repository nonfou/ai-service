# 完整 Docker 部署示例

# Spring / 服务端口
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# 数据存储
DB_PATH=/app/data/ai_api_platform.db

# 安全配置
JWT_SECRET=replace_with_secure_jwt_secret
JWT_EXPIRATION=604800000
JWT_ISSUER=ai-service
ENCRYPTION_KEY=replace_with_32_chars_secret_key

# Copilot 上游代理
COPILOT_PROXY_BASE_URL=
COPILOT_PROXY_API_KEY=
COPILOT_PROXY_CONNECT_TIMEOUT_MS=10000
COPILOT_PROXY_READ_TIMEOUT_MS=600000
COPILOT_PROXY_STREAM_TIMEOUT_MS=1800000

# 对外入口与限流
PUBLIC_PORT=9000
ADMIN_RATE_LIMIT=60
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=60
RATE_LIMIT_API_RPM=30

# JVM
JAVA_OPTS=-Xmx512m -Xms256m
