# ====================================================
# AI API Platform - 生产环境 H2 文件存储示例
# 复制此文件为 .env 并填写实际值
# ====================================================

# Spring 配置
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
DB_PATH=/app/data/ai_api_platform

# ====================================================
# 安全配置 (必需)
# ====================================================
# JWT 密钥 - 至少32字符，建议使用: openssl rand -base64 32
JWT_SECRET=replace_with_secure_jwt_secret
JWT_EXPIRATION=604800000
JWT_ISSUER=api.example.com

# 验证码加密密钥
VERIFY_CODE_SECRET=replace_with_verify_code_secret

# 数据加密密钥 - 必须是16/24/32字节
ENCRYPTION_KEY=replace_with_32_chars_secret_key

# ====================================================
# 邮件配置 (可选，用于验证码发送)
# ====================================================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=service@example.com
MAIL_PASSWORD=replace_with_mail_password
MAIL_SSL_ENABLE=false
MAIL_STARTTLS_ENABLE=true

# ====================================================
# Cookie/Session 安全配置
# ====================================================
SESSION_COOKIE_SECURE=true
COOKIE_SECURE=true

# ====================================================
# 工单通知配置 (可选)
# ====================================================
TICKET_NOTIFY_ENABLED=true
TICKET_ADMIN_EMAIL=admin@example.com
TICKET_ADMIN_CONSOLE_URL=https://admin.example.com
TICKET_USER_PORTAL_URL=https://portal.example.com

# ====================================================
# 后端代理配置
# ====================================================
COPILOT_PROXY_BASE_URL=http://host.docker.internal:4141/v1
COPILOT_PROXY_API_KEY=

# ====================================================
# 管理后台安全配置
# ====================================================
ADMIN_ENABLE_RATE_LIMIT=true
ADMIN_RATE_LIMIT=60
ADMIN_ENABLE_LOGIN_LOCK=true

# ====================================================
# JVM 配置 (可选)
# ====================================================
JAVA_OPTS=-Xmx512m -Xms256m
