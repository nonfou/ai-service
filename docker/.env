# ====================================================
# AI API Platform - Docker 环境配置示例
# 复制此文件为 .env 并填写实际值
# ====================================================

# Spring 配置
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ====================================================
# 数据库配置 (必需)
# ====================================================
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=ai_api_platform
MYSQL_USER=ai_api_platform
MYSQL_PASSWORD=test123
MYSQL_PORT=3306

# ====================================================
# Redis 配置
# ====================================================
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_PORT=6379

# ====================================================
# 安全配置 (必需)
# ====================================================
# JWT 密钥 - 至少32字符，建议使用: openssl rand -base64 32
JWT_SECRET=3vvxhJjlmCXxgh3pL7VwFoJBq0R8McUnBC3Ov8ber2A=
JWT_EXPIRATION=604800000
JWT_ISSUER=23.252.106.80

# 验证码加密密钥
VERIFY_CODE_SECRET=Og1AWi9mti20o+Qt0j9Kij/DUIFSOy1bRGvwnXY7DCg=

# 数据加密密钥 - 必须是16/24/32字节
ENCRYPTION_KEY=7RUzkFK69uXPo8tNpPKQunFtWnCbDvfR

# ====================================================
# 邮件配置 (可选，用于验证码发送)
# ====================================================
MAIL_HOST=smtp.exmail.qq.com
MAIL_PORT=465
MAIL_USERNAME=support@xcoder.plus
MAIL_PASSWORD=od8vgwT878ny7ebn
MAIL_SSL_ENABLE=true
MAIL_STARTTLS_ENABLE=false

# ====================================================
# Cookie/Session 安全配置
# 注意：如果通过 HTTP 访问（非 HTTPS），必须设置为 false
# ====================================================
SESSION_COOKIE_SECURE=false
COOKIE_SECURE=false

# ====================================================
# 工单通知配置 (可选)
# ====================================================
TICKET_NOTIFY_ENABLED=true
TICKET_ADMIN_EMAIL=admin@example.com
TICKET_ADMIN_CONSOLE_URL=https://admin.example.com
TICKET_USER_PORTAL_URL=https://portal.example.com

# ====================================================
# 后端代理配置
# ====================================================
BACKEND_DEFAULT_PROVIDER=copilot
COPILOT_PROXY_BASE_URL=http://67.209.176.51:2235
COPILOT_PROXY_API_KEY=dummy

# ====================================================
# OpenRouter 配置 (可选)
# ====================================================
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ACCOUNT_1_KEY=
OPENROUTER_ACCOUNT_1_ENABLED=false

# ====================================================
# 管理后台安全配置
# ====================================================
ADMIN_ENABLE_RATE_LIMIT=true
ADMIN_RATE_LIMIT=60
ADMIN_ENABLE_LOGIN_LOCK=true

# ====================================================
# JVM 配置 (可选)
# ====================================================
JAVA_OPTS=-Xmx512m -Xms256m
