# 最小 Copilot 代理部署

# 仅需配置一个 Copilot Relay 地址；本服务会对外暴露 `/v1/*` 兼容接口。

SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
COPILOT_PROXY_BASE_URL=http://127.0.0.1:4141/v1
COPILOT_PROXY_API_KEY=
COPILOT_PROXY_CONNECT_TIMEOUT_MS=10000
COPILOT_PROXY_READ_TIMEOUT_MS=600000
COPILOT_PROXY_STREAM_TIMEOUT_MS=1800000
COPILOT_PROXY_WARMUP_MODEL=claude-haiku-4.5
JAVA_OPTS=-Xmx512m -Xms256m
