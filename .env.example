# ====================================================
# AI API Platform - 环境变量配置示例
# ====================================================
# 使用说明:
# 1. 复制此文件为 .env (不要提交到版本控制)
# 2. 填写实际的配置值
# 3. 确保所有必需的变量都已设置
# ====================================================

# ====================================================
# 基础配置
# ====================================================

# 应用端口
SERVER_PORT=8080

# 激活的环境 (dev, prod)
SPRING_PROFILES_ACTIVE=dev

# ====================================================
# 安全配置 (必需)
# ====================================================

# JWT 密钥 - 至少32字符
# 生成方法: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-min-32-characters-long

# JWT 过期时间 (毫秒, 7天 = 604800000)
JWT_EXPIRATION=604800000

# 验证码哈希密钥
# 生成方法: openssl rand -base64 16
VERIFY_CODE_SECRET=your-verify-code-secret

# 加密密钥 (32字节 hex)
# 生成方法: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ====================================================
# 数据库配置 (必需)
# ====================================================

# 数据库连接URL
# 开发环境示例: jdbc:mysql://localhost:3306/ai_api_platform?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai
# 生产环境示例: jdbc:mysql://your-db-host:3306/ai_api_platform?useUnicode=true&characterEncoding=utf-8&useSSL=true&requireSSL=true&serverTimezone=Asia/Shanghai
DB_URL=jdbc:mysql://localhost:3306/ai_api_platform?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai

# 数据库用户名
DB_USERNAME=root

# 数据库密码
DB_PASSWORD=your-database-password

# MySQL root 密码 (用于Docker部署)
MYSQL_ROOT_PASSWORD=root123

# MySQL 数据库名
MYSQL_DATABASE=ai_api_platform

# ====================================================
# Redis 配置 (必需)
# ====================================================

# Redis 主机地址
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码 (如果Redis启用了密码验证)
REDIS_PASSWORD=

# Redis 数据库编号
REDIS_DATABASE=0

# ====================================================
# 邮件配置 (必需)
# ====================================================

# 邮件服务器地址
# QQ邮箱: smtp.qq.com
# 腾讯企业邮箱: smtp.exmail.qq.com
# Gmail: smtp.gmail.com
MAIL_HOST=smtp.exmail.qq.com

# 邮件服务器端口
# STARTTLS: 587
# SSL: 465
MAIL_PORT=465

# 邮箱账号
MAIL_USERNAME=support@your-domain.com

# 邮箱密码或授权码
MAIL_PASSWORD=your-mail-password-or-auth-code

# 是否启用SSL (true/false)
MAIL_SSL_ENABLE=true

# Socket工厂类 (SSL时需要)
MAIL_SOCKET_FACTORY_CLASS=javax.net.ssl.SSLSocketFactory

# 是否启用STARTTLS
MAIL_STARTTLS_ENABLE=false
MAIL_STARTTLS_REQUIRED=false

# ====================================================
# 工单通知配置
# ====================================================

TICKET_NOTIFY_ENABLED=true
TICKET_ADMIN_EMAIL=support@your-domain.com

# ====================================================
# 支付宝配置 (可选)
# ====================================================

# 支付宝应用ID
ALIPAY_APP_ID=your-alipay-app-id

# 支付宝商户私钥
ALIPAY_PRIVATE_KEY=your-alipay-private-key

# 支付宝公钥
ALIPAY_PUBLIC_KEY=your-alipay-public-key

# 支付宝网关 URL
# 沙箱环境: https://openapi.alipaydev.com/gateway.do
# 正式环境: https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY_URL=https://openapi.alipaydev.com/gateway.do

# 支付宝异步通知地址 (必须使用 HTTPS)
ALIPAY_NOTIFY_URL=https://your-domain.com/api/recharge/alipay/notify

# 支付宝同步跳转地址
ALIPAY_RETURN_URL=https://your-domain.com/wallet

# ====================================================
# 微信支付配置 (可选)
# ====================================================

# 微信应用ID
WECHAT_APP_ID=your-wechat-app-id

# 微信商户号
WECHAT_MCH_ID=your-wechat-mch-id

# 微信 API v3 密钥
WECHAT_API_V3_KEY=your-wechat-api-v3-key

# 微信商户证书序列号
WECHAT_MERCHANT_SERIAL_NUMBER=your-merchant-serial-number

# 微信商户私钥路径
WECHAT_PRIVATE_KEY_PATH=classpath:apiclient_key.pem

# 微信异步通知地址 (必须使用 HTTPS)
WECHAT_NOTIFY_URL=https://your-domain.com/api/recharge/wechat/notify

# ====================================================
# 管理后台安全配置
# ====================================================

# 是否启用IP白名单
ADMIN_ENABLE_IP_WHITELIST=false

# IP白名单 (逗号分隔)
ADMIN_IP_WHITELIST=

# 是否启用请求频率限制
ADMIN_ENABLE_RATE_LIMIT=true

# 每分钟最大请求数
ADMIN_RATE_LIMIT=60

# 是否启用登录失败锁定
ADMIN_ENABLE_LOGIN_LOCK=true

# 最大登录失败次数
ADMIN_MAX_LOGIN_ATTEMPTS=5

# 锁定时长 (分钟)
ADMIN_LOCK_DURATION=30

# ====================================================
# 后端账户配置 (可选)
# ====================================================

# Copilot API 基础URL
COPILOT_BASE_URL=https://api.githubcopilot.com

# OpenRouter API 基础URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 是否获取实时价格
OPENROUTER_FETCH_REALTIME_PRICING=true

# OpenRouter 账户配置 (可选)
OPENROUTER_ACCOUNT_1_NAME=openrouter-1
OPENROUTER_ACCOUNT_1_KEY=
OPENROUTER_ACCOUNT_1_ENABLED=false

OPENROUTER_ACCOUNT_2_NAME=openrouter-2
OPENROUTER_ACCOUNT_2_KEY=
OPENROUTER_ACCOUNT_2_ENABLED=false

# ====================================================
# 计费和配额配置
# ====================================================

# 定价加成倍率 (1.2 = 20%利润)
PRICING_MARKUP_RATE=1.2

# 输入 Token 价格 (每百万tokens,元)
INPUT_TOKEN_PRICE=4.1

# 输出 Token 价格 (每百万tokens,元)
OUTPUT_TOKEN_PRICE=16.4

# 默认每日配额 (元)
QUOTA_DEFAULT_DAILY_LIMIT=100.00

# 默认每月配额 (元)
QUOTA_DEFAULT_MONTHLY_LIMIT=2000.00

# 配额告警阈值 (百分比)
QUOTA_ALERT_THRESHOLD=80.0

# ====================================================
# 限流配置
# ====================================================

# 每分钟请求数限制
RATE_LIMIT_PER_MINUTE=60

# ====================================================
# 其他配置 (可选)
# ====================================================

# 验证码TTL (秒)
AUTH_VERIFY_CODE_TTL_SECONDS=300

# 验证码最小间隔 (秒)
AUTH_VERIFY_CODE_MIN_INTERVAL=60

# 每小时最多发送验证码次数
AUTH_VERIFY_CODE_MAX_PER_HOUR=10

# 系统配置缓存TTL (秒)
SYSTEM_CONFIG_CACHE_TTL=60

# ====================================================
# 安全提示
# ====================================================
# 1. 永远不要将 .env 文件提交到版本控制系统
# 2. 生产环境必须使用强密码和随机密钥
# 3. 定期更换密钥和密码
# 4. 限制对环境变量的访问权限
# 5. 使用密钥管理服务 (如 AWS Secrets Manager, Azure Key Vault)
#
# 密钥生成命令:
# - JWT密钥: openssl rand -base64 32
# - 加密密钥: openssl rand -hex 32
# - 通用密钥: openssl rand -base64 16
#
# 注意：外部 API 服务（如 Copilot API）需要单独部署
# 并通过后台管理系统配置 API 端点
# ====================================================
