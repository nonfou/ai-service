# MySQL 配置
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=ai_api_platform

# 邮件配置（可选，用于验证码登录）
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-auth-code

# JWT 密钥（建议修改）
JWT_SECRET=your-secret-key-change-this-in-production-min-256-bits

# 计费配置
INPUT_TOKEN_PRICE=4.1
OUTPUT_TOKEN_PRICE=16.4

# 限流配置
RATE_LIMIT_PER_MINUTE=60

# 注意：外部 API 服务（如 Copilot API）需要单独部署
# 并通过后台管理系统配置 API 端点
