# ==============================================
# AI API Platform - 环境变量配置示例
# ==============================================
# 复制此文件为 .env 并填写实际配置值
# 注意: .env 文件包含敏感信息，已在 .gitignore 中排除

# ==============================================
# 数据库配置
# ==============================================
DB_URL=jdbc:mysql://localhost:3306/ai_api_platform?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=your-database-password

# ==============================================
# Redis 配置
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ==============================================
# 邮件服务配置
# ==============================================
# 邮件服务器地址
MAIL_HOST=smtp.exmail.qq.com
# 邮件服务器端口 (465 for SSL, 587 for STARTTLS)
MAIL_PORT=465
# 发件人邮箱地址
MAIL_USERNAME=support@xcoder.plus
# 邮件密码或授权码
MAIL_PASSWORD=od8vgwT878ny7ebn

# SSL/STARTTLS 配置（根据端口自动配置）
# 465端口使用SSL：
MAIL_SSL_ENABLE=true
MAIL_SOCKET_FACTORY_CLASS=javax.net.ssl.SSLSocketFactory
MAIL_STARTTLS_ENABLE=false
MAIL_STARTTLS_REQUIRED=false

# 587端口使用STARTTLS（如需使用587端口，修改为以下配置）：
# MAIL_PORT=587
# MAIL_SSL_ENABLE=false
# MAIL_SOCKET_FACTORY_CLASS=
# MAIL_STARTTLS_ENABLE=true
# MAIL_STARTTLS_REQUIRED=true

# 常见邮件服务商配置示例:
# 腾讯企业邮箱 (SSL - 推荐):
#   MAIL_HOST=smtp.exmail.qq.com
#   MAIL_PORT=465
#   MAIL_SSL_ENABLE=true
#   MAIL_SOCKET_FACTORY_CLASS=javax.net.ssl.SSLSocketFactory
#   MAIL_STARTTLS_ENABLE=false
#
# 腾讯企业邮箱 (STARTTLS):
#   MAIL_HOST=smtp.exmail.qq.com
#   MAIL_PORT=587
#   MAIL_SSL_ENABLE=false
#   MAIL_SOCKET_FACTORY_CLASS=
#   MAIL_STARTTLS_ENABLE=true
#
# QQ邮箱 (STARTTLS):
#   MAIL_HOST=smtp.qq.com
#   MAIL_PORT=587
#   MAIL_SSL_ENABLE=false
#   MAIL_STARTTLS_ENABLE=true
#
# 163邮箱 (SSL):
#   MAIL_HOST=smtp.163.com
#   MAIL_PORT=465
#   MAIL_SSL_ENABLE=true
#   MAIL_SOCKET_FACTORY_CLASS=javax.net.ssl.SSLSocketFactory
# Gmail (STARTTLS):
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
# 腾讯企业邮箱 (SSL):
#   MAIL_HOST=smtp.exmail.qq.com
#   MAIL_PORT=465

# ==============================================
# JWT 配置
# ==============================================
# JWT 密钥（必须是强随机字符串，建议256位以上）
# 生成方式: openssl rand -base64 32
JWT_SECRET=0Qu/3sEdrbX+2BmxsMeahKQYlZpbhdArOCBY2FXFYRo=
# JWT 过期时间（毫秒）默认7天
JWT_EXPIRATION=604800000

# ==============================================
# Copilot API 配置（支持多端点和自动故障转移）
# ==============================================

# 主端点配置（必须配置）
COPILOT_PRIMARY_NAME=primary
COPILOT_PRIMARY_URL=http://localhost:4141
COPILOT_PRIMARY_TOKEN=ghp_your_primary_github_token
COPILOT_PRIMARY_ENABLED=true

# 备用端点1配置（可选）
# 取消注释以启用备用端点
# COPILOT_BACKUP1_NAME=backup1
# COPILOT_BACKUP1_URL=http://backup-server:4141
# COPILOT_BACKUP1_TOKEN=ghp_your_backup1_github_token
# COPILOT_BACKUP1_ENABLED=true

# 备用端点2配置（可选）
# COPILOT_BACKUP2_NAME=backup2
# COPILOT_BACKUP2_URL=http://another-server:4141
# COPILOT_BACKUP2_TOKEN=ghp_your_backup2_github_token
# COPILOT_BACKUP2_ENABLED=true

# 故障转移配置
COPILOT_FAILOVER_ENABLED=true        # 是否启用自动故障转移
COPILOT_MAX_RETRIES=3                # 单个端点最大重试次数
COPILOT_TIMEOUT=5000                 # 请求超时时间（毫秒）
COPILOT_HEALTH_CHECK_INTERVAL=30     # 健康检查间隔（秒）

# 配置说明：
# 1. 每个端点都需要配置独立的 URL 和 Token
# 2. priority 在配置文件中设置，数字越小优先级越高
# 3. 当主端点失败时，自动切换到备用端点
# 4. 不健康的端点会被定期检查，恢复后自动重新启用
# 5. 如果只有一个端点，可以不配置备用端点

# ==============================================
# 应用配置
# ==============================================
# Spring 配置文件激活 (dev/test/prod)
SPRING_PROFILES_ACTIVE=dev
# 服务端口
SERVER_PORT=8080

# ==============================================
# 安全建议
# ==============================================
# 1. 生产环境必须修改所有默认密码和密钥
# 2. JWT_SECRET 必须使用强随机字符串
# 3. 不要将 .env 文件提交到版本控制系统
# 4. 定期更新密码和密钥
# 5. 使用配置中心管理生产环境配置（如 Nacos、Apollo）
