<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 引入 Spring Boot 默认配置 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- 日志输出格式 -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n"/>

    <!-- 日志文件路径 -->
    <property name="LOG_PATH" value="${LOG_PATH:-logs}"/>

    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 文件输出 - 普通日志 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/app.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/app-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 文件输出 - 安全审计日志 -->
    <appender name="SECURITY" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/security.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/security-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>90</maxHistory>  <!-- 安全日志保留90天 -->
            <totalSizeCap>50GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 文件输出 - 错误日志 -->
    <appender name="ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/error-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 安全相关日志单独输出 -->
    <logger name="com.nonfou.github.service.AuthService" level="INFO" additivity="false">
        <appender-ref ref="SECURITY"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="com.nonfou.github.service.AdminService" level="INFO" additivity="false">
        <appender-ref ref="SECURITY"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="com.nonfou.github.config.JwtAuthenticationFilter" level="INFO" additivity="false">
        <appender-ref ref="SECURITY"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="com.nonfou.github.interceptor.AdminSecurityInterceptor" level="INFO" additivity="false">
        <appender-ref ref="SECURITY"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- MyBatis SQL 日志 (开发环境DEBUG,生产环境建议关闭) -->
    <logger name="com.nonfou.github.mapper" level="INFO"/>

    <!-- MyBatis-Plus 框架日志 -->
    <logger name="com.baomidou.mybatisplus" level="INFO"/>

    <!-- Spring 框架日志 -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="INFO"/>

    <!-- 开发环境配置 -->
    <springProfile name="dev">
        <!-- MyBatis SQL 日志在开发环境启用 -->
        <logger name="com.nonfou.github.mapper" level="DEBUG"/>
        <logger name="com.baomidou.mybatisplus" level="DEBUG"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR"/>
        </root>
    </springProfile>

    <!-- 生产环境配置 -->
    <springProfile name="prod">
        <!-- 生产环境只输出 WARN 及以上级别 -->
        <root level="WARN">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR"/>
        </root>

        <!-- MyBatis 日志在生产环境只记录警告和错误 -->
        <logger name="com.nonfou.github.mapper" level="WARN"/>
        <logger name="com.baomidou.mybatisplus" level="WARN"/>

        <!-- 安全日志保持 INFO 级别 -->
        <logger name="com.nonfou.github.service.AuthService" level="INFO"/>
        <logger name="com.nonfou.github.service.AdminService" level="INFO"/>
        <logger name="com.nonfou.github.config.JwtAuthenticationFilter" level="INFO"/>
        <logger name="com.nonfou.github.interceptor.AdminSecurityInterceptor" level="INFO"/>
    </springProfile>

    <!-- 默认配置 (无 profile 时使用) -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR"/>
    </root>
</configuration>
